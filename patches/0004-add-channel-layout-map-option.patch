+static const char *clm_map_label(const char *label)
+{
+    if (!av_strcasecmp(label, "L"))   return "FL";
+    if (!av_strcasecmp(label, "R"))   return "FR";
+    if (!av_strcasecmp(label, "C"))   return "FC";
+    if (!av_strcasecmp(label, "LFE")) return "LFE";
+    if (!av_strcasecmp(label, "LS"))  return "SL";
+    if (!av_strcasecmp(label, "RS"))  return "SR";
+    if (!av_strcasecmp(label, "LT"))  return "DL";
+    if (!av_strcasecmp(label, "RT"))  return "DR";
+
+    if (!av_strcasecmp(label, "FL")  || !av_strcasecmp(label, "FR") ||
+        !av_strcasecmp(label, "FC")  || !av_strcasecmp(label, "LFE") ||
+        !av_strcasecmp(label, "SL")  || !av_strcasecmp(label, "SR") ||
+        !av_strcasecmp(label, "BL")  || !av_strcasecmp(label, "BR") ||
+        !av_strcasecmp(label, "BC")  || !av_strcasecmp(label, "DL") ||
+        !av_strcasecmp(label, "DR")  || !av_strcasecmp(label, "TFL") ||
+        !av_strcasecmp(label, "TFC") || !av_strcasecmp(label, "TFR") ||
+        !av_strcasecmp(label, "TBL") || !av_strcasecmp(label, "TBC") ||
+        !av_strcasecmp(label, "TBR"))
+        return label;
+
+    return NULL;
+}
+
+static int clm_expand_input_side(void *logctx, const char *spec,
+                                 int *src_idx, int max_src_idx,
+                                 int *nb_out)
+{
+    char *work = av_strdup(spec);
+    char *saveptr = NULL;
+    char *tok;
+    int n = 0;
+
+    if (!work)
+        return AVERROR(ENOMEM);
+
+    for (tok = av_strtok(work, ",", &saveptr); tok; tok = av_strtok(NULL, ",", &saveptr)) {
+        int a = -1, b = -1;
+
+        if (sscanf(tok, "%d-%d", &a, &b) == 2) {
+            if (a < 0 || b < 0 || n + 2 > max_src_idx) {
+                av_log(logctx, AV_LOG_ERROR, "Invalid channel index range '%s' in channel_layout_map\n", tok);
+                av_free(work);
+                return AVERROR(EINVAL);
+            }
+            src_idx[n++] = a;
+            src_idx[n++] = b;
+        } else if (sscanf(tok, "%d", &a) == 1) {
+            if (a < 0 || n + 1 > max_src_idx) {
+                av_log(logctx, AV_LOG_ERROR, "Invalid channel index '%s' in channel_layout_map\n", tok);
+                av_free(work);
+                return AVERROR(EINVAL);
+            }
+            src_idx[n++] = a;
+        } else {
+            av_log(logctx, AV_LOG_ERROR, "Invalid input map token '%s' in channel_layout_map\n", tok);
+            av_free(work);
+            return AVERROR(EINVAL);
+        }
+    }
+
+    av_free(work);
+    *nb_out = n;
+    return 0;
+}
+
+static int clm_expand_output_side(void *logctx, const char *spec,
+                                  char dst_labels[][8], int max_labels,
+                                  int *nb_out)
+{
+    char *work = av_strdup(spec);
+    char *saveptr = NULL;
+    char *tok;
+    int n = 0;
+
+    if (!work)
+        return AVERROR(ENOMEM);
+
+    for (tok = av_strtok(work, ",", &saveptr); tok; tok = av_strtok(NULL, ",", &saveptr)) {
+        char *dash = strchr(tok, '-');
+
+        if (dash) {
+            *dash = '\0';
+            dash++;
+            if (n + 2 > max_labels) {
+                av_free(work);
+                return AVERROR(EINVAL);
+            }
+            av_strlcpy(dst_labels[n++], tok, 8);
+            av_strlcpy(dst_labels[n++], dash, 8);
+        } else {
+            if (n + 1 > max_labels) {
+                av_free(work);
+                return AVERROR(EINVAL);
+            }
+            av_strlcpy(dst_labels[n++], tok, 8);
+        }
+    }
+
+    av_free(work);
+    *nb_out = n;
+    return 0;
 }
 
+static int clm_build_filter(void *logctx, const char *spec, char **dst)
+{
+    const char *sep = strchr(spec, ':');
+    char *left = NULL;
+    int src_idx[64], n_src = 0;
+    char labels[64][8], mapped[64][8];
+    int n_labels = 0;
+    AVBPrint map_bp, layout_bp, out_bp;
+    int ret;
+
+    if (!sep || sep == spec || !sep[1]) {
+        av_log(logctx, AV_LOG_ERROR, "Invalid channel_layout_map format. Expected in_map:out_labels\n");
+        return AVERROR(EINVAL);
+    }
+
+    left = av_strndup(spec, sep - spec);
+    if (!left)
+        return AVERROR(ENOMEM);
+
+    ret = clm_expand_input_side(logctx, left, src_idx, FF_ARRAY_ELEMS(src_idx), &n_src);
+    if (ret < 0) {
+        av_free(left);
+        return ret;
+    }
+
+    ret = clm_expand_output_side(logctx, sep + 1, labels, FF_ARRAY_ELEMS(labels), &n_labels);
+    av_free(left);
+    if (ret < 0)
+        return ret;
+
+    if (n_src != n_labels || n_src <= 0) {
+        av_log(logctx, AV_LOG_ERROR, "channel_layout_map count mismatch: %d input channels vs %d output labels\n",
+               n_src, n_labels);
+        return AVERROR(EINVAL);
+    }
+
+    av_bprint_init(&map_bp, 0, AV_BPRINT_SIZE_UNLIMITED);
+    av_bprint_init(&layout_bp, 0, AV_BPRINT_SIZE_UNLIMITED);
+    av_bprint_init(&out_bp, 0, AV_BPRINT_SIZE_UNLIMITED);
+
+    for (int i = 0; i < n_labels; i++) {
+        const char *ml = clm_map_label(labels[i]);
+        if (!ml) {
+            av_log(logctx, AV_LOG_ERROR, "Unknown output label '%s' in channel_layout_map\n", labels[i]);
+            ret = AVERROR(EINVAL);
+            goto fail;
+        }
+        av_strlcpy(mapped[i], ml, sizeof(mapped[i]));
+        av_bprintf(&map_bp, "%s%d-%s", i ? "|" : "", src_idx[i], mapped[i]);
+        av_bprintf(&layout_bp, "%s%s", i ? "+" : "", mapped[i]);
+    }
+
+    av_bprintf(&out_bp, "channelmap=map=%s:channel_layout=%s", map_bp.str, layout_bp.str);
+    if (!av_bprint_is_complete(&out_bp)) {
+        ret = AVERROR(ENOMEM);
+        goto fail;
+    }
+
+    *dst = av_strdup(out_bp.str);
+    ret = *dst ? 0 : AVERROR(ENOMEM);
+
+fail:
+    av_bprint_finalize(&map_bp, NULL);
+    av_bprint_finalize(&layout_bp, NULL);
+    av_bprint_finalize(&out_bp, NULL);
+    return ret;
+}
